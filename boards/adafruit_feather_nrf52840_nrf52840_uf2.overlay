/*
 * Devicetree overlay for Adafruit Feather nRF52840 Express
 * with Adafruit Music Maker FeatherWing (VS1053B + SD card)
 * and LIS2DW12 accelerometer.
 *
 * Feather pin mapping (nRF52840 GPIO):
 *   D5  = P1.08  ->  SD card CS (directly on FeatherWing)
 *   D6  = P0.07  ->  VS1053B XCS  (SCI command chip select)
 *   D9  = P0.26  ->  VS1053B DREQ (data request, active high)
 *   D10 = P0.27  ->  VS1053B XDCS (SDI data chip select)
 *   A0  = P0.04  ->  LIS2DW12 INT1 (wakeup interrupt)
 *   A1  = P0.05  ->  VS1053B XRESET (hardware reset, active low).
 *                    Requires the FeatherWing RST jumper cut and the
 *                    rst pad wired to A1; lets firmware hold the codec
 *                    in reset (~12 uA) when idle.
 *
 *   SPI bus (feather header):
 *     SCK  = P0.14
 *     MOSI = P0.13
 *     MISO = P0.15
 *
 *   I2C bus (feather header):
 *     SDA  = P0.12
 *     SCL  = P0.11
 *
 *   Battery sense (Feather rev D):
 *     P0.29 = AIN5  ->  VBAT through an on-board 100k/100k divider.
 *                       The divider (the `vbatt` node) is defined by the
 *                       board devicetree; this overlay only adds the
 *                       matching SAADC channel.
 */

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/adc/nrf-saadc.h>

/* OTA flash split: updater @0x26000, this app @0x3e000. */
#include "bleatbox-partitions.dtsi"

/ {
	chosen {
		/* The app runs from main_app; the updater owns 0x26000. */
		zephyr,code-partition = &main_app;
	};

	aliases {
		sdhc0 = &sdhc0;
	};

	/*
	 * Application-specific GPIOs for the VS1053B codec.
	 * XCS and XDCS are SPI chip selects managed via spi_cs_control
	 * (not gpio-leds) so the SPI driver handles bus locking atomically.
	 * DREQ is a pure input — polled to gate SPI transfers.
	 * XRESET (active low) holds the codec in hardware reset when idle.
	 */
	zephyr,user {
		vs1053b-xcs-gpios = <&gpio0 7 GPIO_ACTIVE_LOW>;
		vs1053b-xdcs-gpios = <&gpio0 27 GPIO_ACTIVE_LOW>;
		vs1053b-dreq-gpios = <&gpio0 26 GPIO_ACTIVE_HIGH>;
		vs1053b-reset-gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;
	};
};

&uart0 {
	status = "disabled";
};

/*
 * SAADC channel for the battery-sense divider on AIN5 (P0.29).
 * Gain 1/6 with the 0.6 V internal reference gives a 3.6 V full-scale
 * range, comfortably above the divided VBAT (~2.1 V at 4.2 V battery).
 */
&adc {
	#address-cells = <1>;
	#size-cells = <0>;

	channel@5 {
		reg = <5>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
		zephyr,input-positive = <NRF_SAADC_AIN5>;
		zephyr,resolution = <12>;
	};
};

&i2c0 {
	lis2dw12: lis2dw12@19 {
		compatible = "st,lis2dw12";
		reg = <0x19>;
		irq-gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
		int-pin = <1>;
		power-mode = <0>; /* LP mode 1 (12-bit) */
		odr = <100>;
		range = <2>;
		wakeup-duration = <0>; /* 1 ODR cycle above threshold */
	};
};

&spi1 {
	status = "okay";
	cs-gpios = <&gpio1 8 GPIO_ACTIVE_LOW>;

	sdhc0: sdhc@0 {
		compatible = "zephyr,sdhc-spi-slot";
		reg = <0>;
		spi-max-frequency = <8000000>;
		status = "okay";

		mmc {
			compatible = "zephyr,sdmmc-disk";
			disk-name = "SD";
			status = "okay";
		};
	};
};
